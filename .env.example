# Chiave API gratuita di Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modello del giudice. Default gemini-2.5-flash-lite: il più generoso sul free tier
# (~30 RPM) e quindi il più resistente ai rate limit. Per qualità di ragionamento
# superiore puoi mettere gemini-2.0-flash (15 RPM) o gemini-2.5-flash (~10 RPM),
# accettando limiti/minuto più stretti.
GEMINI_MODEL=gemini-2.5-flash-lite
# Modello per la pre-elaborazione (estrazione carte/termini): basta il lite.
GEMINI_MODEL_FAST=gemini-2.5-flash-lite

# Gate di accesso del deploy pubblico (HF Spaces). Se impostata, l'app richiede questa
# password via HTTP Basic Auth (username qualsiasi). Lasciala vuota in locale per disattivarla.
APP_PASSWORD=
